{
  "name": "toolhive-studio",
  "productName": "ToolHive",
  "version": "0.0.0-dev",
  "description": "ToolHive is an application that allows you to install, manage and run MCP servers and connect them to AI agents and clients",
  "main": ".vite/build/main.js",
  "repository": "https://github.com/stacklok/toolhive-studio",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "start": "electron-forge start",
    "start:inspect": "tsx scripts/start-inspect.ts",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "pnpm run rebuild",
    "e2e": "pnpm package && pnpm e2e:prebuilt",
    "e2e:prebuilt": "playwright test",
    "package": "tsc -b --clean && tsc -b && electron-forge package",
    "make": "tsc -b --clean && tsc -b && electron-forge make",
    "prettier": "prettier . --check",
    "format": "prettier . --write",
    "lint": "eslint .",
    "publish": "electron-forge publish",
    "type-check": "tsc --noEmit -p ./tsconfig.app.json && tsc --noEmit -p ./tsconfig.node.json",
    "prepare": "husky install",
    "thv": "rimraf bin/ && tsx ./utils/fetch-thv.ts --run",
    "vitest:electron": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs",
    "test": "pnpm run vitest:electron",
    "test:nonInteractive": "pnpm run vitest:electron run",
    "test:coverage": "pnpm run vitest:electron run --coverage",
    "update-api": "tsx scripts/update-api.ts",
    "generate-client": "pnpm run update-api && cd common/api && openapi-ts",
    "generate-client:nofetch": "cd common/api && openapi-ts",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "knip": "knip",
    "deeplink:registerTestLinuxProtocolHandler": "bash scripts/install-deep-link-handler.sh",
    "devContainer:dev": "bash scripts/devcontainer-dev.sh"
  },
  "keywords": [],
  "license": "Apache-2.0",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-base": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron-forge/publisher-s3": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@electron/fuses": "^2.1.2",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/regexp.escape": "^2.0.0",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "electron": "42.5.0",
    "electron-winstaller": "^5.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "icon-gen": "^5.0.0",
    "jsdom": "^29.1.1",
    "json-schema-faker": "^0.6.2",
    "knip": "^6.21.0",
    "lint-staged": "^16.4.0",
    "memfs": "^4.57.2",
    "msw": "^2.14.6",
    "prettier": "3.8.4",
    "prettier-plugin-classnames": "^0.10.1",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "tar": "^7.5.15",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.3",
    "unzipper": "^0.12.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-fail-on-console": "^0.10.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.87",
    "@ai-sdk/google": "^3.0.84",
    "@ai-sdk/mcp": "^1.0.53",
