{
  "name": "toolhive-studio",
  "productName": "ToolHive",
  "version": "0.0.0-dev",
  "description": "ToolHive is an application that allows you to install, manage and run MCP servers and connect them to AI agents and clients",
  "main": ".vite/build/main.js",
  "repository": "https://github.com/stacklok/toolhive-studio",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "start": "electron-forge start",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "pnpm run rebuild",
    "e2e": "pnpm package && pnpm e2e:prebuilt",
    "e2e:prebuilt": "playwright test",
    "package": "tsc -b --clean && tsc -b && electron-forge package",
    "make": "tsc -b --clean && tsc -b && electron-forge make",
    "prettier": "prettier . --check",
    "format": "prettier . --write",
    "lint": "eslint .",
    "publish": "electron-forge publish",
    "type-check": "tsc --noEmit -p ./tsconfig.app.json && tsc --noEmit -p ./tsconfig.node.json",
    "prepare": "husky install",
    "thv": "rimraf bin/ && tsx ./utils/fetch-thv.ts --run",
    "vitest:electron": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs",
    "test": "pnpm run vitest:electron",
    "test:nonInteractive": "pnpm run vitest:electron run",
    "test:coverage": "pnpm run vitest:electron run --coverage",
    "update-api": "tsx scripts/update-api.ts",
    "generate-client": "pnpm run update-api && cd common/api && openapi-ts",
    "generate-client:nofetch": "cd common/api && openapi-ts",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "knip": "knip",
    "deeplink:registerTestLinuxProtocolHandler": "bash scripts/install-deep-link-handler.sh"
  },
  "keywords": [],
  "license": "Apache-2.0",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-base": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/publisher-s3": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "0.94.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/regexp.escape": "^2.0.0",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.0.0",
    "electron": "40.8.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "icon-gen": "^5.0.0",
    "jsdom": "^29.0.1",
    "json-schema-faker": "^0.5.9",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "memfs": "^4.50.0",
    "msw": "^2.8.4",
    "prettier": "3.8.1",
    "prettier-plugin-classnames": "^0.9.0",
    "prettier-plugin-merge": "^0.10.0",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "rimraf": "^6.1.3",
    "tar": "^7.5.6",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2",
    "unzipper": "^0.12.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-fail-on-console": "^0.10.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai": "^3.0.48",
